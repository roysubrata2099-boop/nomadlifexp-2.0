import Link from "next/link";
import { posts } from "@/data/posts";

export default function CategoryPillars() {
    // dynamically extract categories from posts
    const categories = Array.from(
        new Set(posts.map((p) => p.category).filter(Boolean))
    );

    return (
        <section className="grid grid-cols-2 md:grid-cols-4 gap-4 p-6">

            {categories.map((cat) => (
                <Link
                    key={cat}
                    href={`/blog/category/${cat}`}
                    className="
            border p-6 text-center rounded
            hover:bg-black hover:text-white
            transition-all duration-200
            uppercase text-sm tracking-wider
          "
                >
                    {cat}
                </Link>
            ))}

        </section>
    );
}